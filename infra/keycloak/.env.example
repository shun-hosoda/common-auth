# ============================================================
# ⚠️  このファイルはテンプレートです。
#     cp .env.example ../.env を実行して実際の値を設定してください。
#     .env は .gitignore に含まれています。絶対にコミットしないでください。
# ============================================================

# --- Keycloak Admin ---
KEYCLOAK_ADMIN_PASSWORD=your-admin-password-here

# --- Database ---
KC_DB_NAME=keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=your-db-password-here

# --- SMTP（開発環境: mailhog デフォルト・変更不要） ---
KC_SMTP_HOST=mailhog
KC_SMTP_PORT=1025
KC_SMTP_FROM=noreply@example.com
KC_SMTP_AUTH=false
KC_SMTP_SSL=false
KC_SMTP_TLS=false

# --- SMTP 認証情報（本番環境・SMTP認証が必要な場合のみ設定） ---
# KC_SMTP_USER=your-smtp-user-here
# KC_SMTP_PASSWORD=your-smtp-password-here

# --- OTP設定 ---
KC_OTP_EXPIRES_IN=300
KC_COOKIE_MAX_AGE=2592000

# ============================================================
# ⚠️  テストユーザー（開発環境のみ）
#     testuser / Test1234! → 初回ログイン時にパスワード変更が強制されます。
#     本番配布時は realm-export.json の users セクションを削除してください。
# ============================================================
