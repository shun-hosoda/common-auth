{
  "realm": "mfa-realm-totp",
  "enabled": true,
  "displayName": "MFA Realm (TOTP)",
  "loginTheme": "keycloak",
  "sslRequired": "none",
  "registrationAllowed": false,
  "bruteForceProtected": true,
  "failureFactor": 3,
  "waitIncrementSeconds": 60,
  "maxFailureWaitSeconds": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "accessTokenLifespan": 300,
  "otpPolicy": {
    "type": "totp",
    "algorithm": "HmacSHA1",
    "digits": 6,
    "period": 30,
    "lookAheadWindow": 1,
    "initialCounter": 0
  },
  "requiredActions": [
    {
      "alias": "CONFIGURE_TOTP",
      "name": "Configure OTP",
      "providerId": "CONFIGURE_TOTP",
      "enabled": true,
      "defaultAction": true,
      "priority": 10
    },
    {
      "alias": "UPDATE_PASSWORD",
      "name": "Update Password",
      "providerId": "UPDATE_PASSWORD",
      "enabled": true,
      "defaultAction": false,
      "priority": 30
    }
  ],
  "authenticationFlows": [
    {
      "alias": "custom-totp-flow",
      "description": "顧客B向け: TOTPアプリ強制フロー（初回: QR設定 / 2回目以降: コード入力のみ）",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticatorFlow": true,
          "requirement": "ALTERNATIVE",
          "priority": 10,
          "flowAlias": "custom-totp-cookie"
        },
        {
          "authenticatorFlow": true,
          "requirement": "ALTERNATIVE",
          "priority": 20,
          "flowAlias": "custom-totp-forms"
        }
      ]
    },
    {
      "alias": "custom-totp-cookie",
      "description": "Cookie チェック（Phase 2で ALTERNATIVE に変更予定。Phase 1では DISABLED で統一）",
      "providerId": "basic-flow",
      "topLevel": false,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "auth-cookie",
          "requirement": "DISABLED",
          "priority": 10,
          "userSetupAllowed": false
        }
      ]
    },
    {
      "alias": "custom-totp-forms",
      "description": "ID/Password + TOTP（初回: Configure OTP Required Action で QR表示）",
      "providerId": "basic-flow",
      "topLevel": false,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "auth-username-password-form",
          "requirement": "REQUIRED",
          "priority": 10,
          "userSetupAllowed": false
        },
        {
          "authenticator": "auth-otp-form",
          "requirement": "REQUIRED",
          "priority": 20,
          "userSetupAllowed": false
        }
      ]
    },
    {
      "alias": "direct grant",
      "description": "OpenID Connect Resource Owner Grant",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": true,
      "authenticationExecutions": [
        {
          "authenticator": "direct-grant-validate-username",
          "requirement": "REQUIRED",
          "priority": 10
        },
        {
          "authenticator": "direct-grant-validate-password",
          "requirement": "REQUIRED",
          "priority": 20
        }
      ]
    }
  ],
  "browserFlow": "custom-totp-flow",
  "clients": [
    {
      "clientId": "react-app",
      "name": "React Application",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "protocol": "openid-connect"
    }
  ],
  "users": [
    {
      "username": "testuser-totp",
      "email": "testuser-totp@example.com",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "Test1234!",
          "temporary": true
        }
      ]
    }
  ]
}
