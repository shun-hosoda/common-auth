# Keycloak Configuration
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=common-auth
KEYCLOAK_CLIENT_ID=backend-app

# Tenant Configuration
# SaaS BtoB multi-tenant: extract tenant_id from JWT custom claim (user attribute)
TENANT_ID_SOURCE=custom
TENANT_ID_CLAIM=tenant_id
# For realm-per-tenant (on-premise): TENANT_ID_SOURCE=iss
# For single-tenant: TENANT_ID_SOURCE=fixed, TENANT_ID_FIXED=my-tenant

# JWKS Cache
JWKS_CACHE_TTL=86400

# Row-Level Security
ENABLE_RLS=true
ENABLE_USER_SYNC=false

# Database (if using with database)
# DATABASE_URL=postgresql+asyncpg://app_user:app_pass@localhost:5433/app_db
