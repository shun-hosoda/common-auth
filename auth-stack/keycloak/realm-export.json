{
  "realm": "common-auth",
  "displayName": "Common Auth",
  "displayNameHtml": "<div class=\"kc-logo-text\"><span>Common Auth</span></div>",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "rememberMe": true,
  "verifyEmail": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 30,
  "defaultSignatureAlgorithm": "RS256",
  "offlineSessionMaxLifespanEnabled": false,
  "offlineSessionMaxLifespan": 5184000,
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "clientScopes": [
    {
      "name": "tenant",
      "description": "Adds tenant_id claim from user attribute",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "tenant-id-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "tenant_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "tenant_id",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "backend-app",
      "name": "Backend Application",
      "description": "Backend SDK client (confidential)",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "**********",
      "redirectUris": [
        "http://localhost:8000/*",
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:8000",
        "http://localhost:3000"
      ],
      "publicClient": false,
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "fullScopeAllowed": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email",
        "tenant"
      ]
    },
    {
      "clientId": "example-app",
      "name": "Example Application",
      "description": "Example app for frontend (public client)",
      "enabled": true,
      "publicClient": true,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:8000/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:8000"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:3000/*",
        "pkce.code.challenge.method": "S256"
      },
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email",
        "tenant"
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Standard user role",
        "composite": false
      },
      {
        "name": "admin",
        "description": "Legacy administrator role",
        "composite": false
      },
      {
        "name": "tenant_admin",
        "description": "Tenant administrator: can manage users within the tenant",
        "composite": true,
        "composites": {
          "client": {
            "realm-management": [
              "manage-users",
              "view-users",
              "query-users",
              "query-groups",
              "manage-group-membership",
              "view-realm"
            ]
          }
        }
      },
      {
        "name": "super_admin",
        "description": "Super administrator: full realm management",
        "composite": true,
        "composites": {
          "client": {
            "realm-management": [
              "realm-admin"
            ]
          }
        }
      }
    ]
  },
  "groups": [
    {
      "name": "tenants",
      "path": "/tenants",
      "subGroups": [
        {
          "name": "acme-corp",
          "path": "/tenants/acme-corp",
          "attributes": {
            "tenant_id": ["acme-corp"]
          }
        },
        {
          "name": "globex-inc",
          "path": "/tenants/globex-inc",
          "attributes": {
            "tenant_id": ["globex-inc"]
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "testuser@example.com",
      "email": "testuser@example.com",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Test",
      "lastName": "User",
      "attributes": {
        "tenant_id": ["acme-corp"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "password123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user"
      ],
      "groups": [
        "/tenants/acme-corp"
      ]
    },
    {
      "username": "admin@example.com",
      "email": "admin@example.com",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Tenant",
      "lastName": "Admin",
      "attributes": {
        "tenant_id": ["acme-corp"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user",
        "tenant_admin"
      ],
      "groups": [
        "/tenants/acme-corp"
      ]
    },
    {
      "username": "testuser2@example.com",
      "email": "testuser2@example.com",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Test",
      "lastName": "User2",
      "attributes": {
        "tenant_id": ["globex-inc"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "password123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user"
      ],
      "groups": [
        "/tenants/globex-inc"
      ]
    },
    {
      "username": "superadmin@example.com",
      "email": "superadmin@example.com",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Super",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "superadmin123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user",
        "super_admin"
      ]
    }
  ],
  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyInitialCounter": 0,
  "otpPolicyDigits": 6,
  "otpPolicyLookAheadWindow": 1,
  "otpPolicyPeriod": 30,
  "requiredActions": [
    {
      "alias": "CONFIGURE_TOTP",
      "name": "Configure OTP",
      "providerId": "CONFIGURE_TOTP",
      "enabled": true,
      "defaultAction": false,
      "priority": 10
    },
    {
      "alias": "UPDATE_PASSWORD",
      "name": "Update Password",
      "providerId": "UPDATE_PASSWORD",
      "enabled": true,
      "defaultAction": false,
      "priority": 30
    },
    {
      "alias": "VERIFY_EMAIL",
      "name": "Verify Email",
      "providerId": "VERIFY_EMAIL",
      "enabled": true,
      "defaultAction": false,
      "priority": 50
    }
  ],
  "smtpServer": {
    "host": "#{SMTP_HOST}",
    "port": "#{SMTP_PORT}",
    "from": "#{SMTP_FROM}",
    "fromDisplayName": "#{SMTP_FROM_DISPLAY_NAME}",
    "auth": true,
    "user": "#{SMTP_USER}",
    "password": "#{SMTP_PASSWORD}",
    "starttls": "#{SMTP_STARTTLS}",
    "ssl": "#{SMTP_SSL}"
  },
  "internationalizationEnabled": false,
  "supportedLocales": ["en"],
  "defaultLocale": "en",
  "defaultRoles": ["offline_access", "uma_authorization", "user"]
}
