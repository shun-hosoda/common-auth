            ]
          }
        },
        {
          "name": "globex-inc",
          "path": "/tenants/globex-inc",
          "attributes": {
            "tenant_id": [
              "globex-inc"
            ],
            "mfa_enabled": [
              "false"
            ],
            "mfa_method": [
              "totp"
            ]
          }
        }
      ]
    }
  ],
