# Keycloak Database Configuration
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak_pass

# Keycloak Configuration
KEYCLOAK_HOSTNAME=localhost
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Application Database Configuration (for testing/development)
APP_DB_NAME=app_db
APP_DB_USER=app_user
APP_DB_PASSWORD=app_pass
APP_DB_PORT=5433

# SMTP Configuration (for password reset / email verification)
# ローカル開発: MailHog を使用（デフォルト設定のまま動作します）
# 本番環境: 実SMTPサーバーの値に変更してください
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_FROM_DISPLAY_NAME=Common Auth
SMTP_AUTH=false
SMTP_STARTTLS=false
SMTP_SSL=false

# MailHog ポート設定（変更が必要な場合のみ）
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# 本番SMTP例（Gmail）:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_AUTH=true
# SMTP_STARTTLS=true

# Backend SDK Configuration (for examples)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=common-auth
KEYCLOAK_CLIENT_ID=backend-app
# SaaS BtoB: custom claim from user attribute (tenant_id)
# For single-tenant or realm-per-tenant: use "iss"
TENANT_ID_SOURCE=custom
TENANT_ID_CLAIM=tenant_id
JWKS_CACHE_TTL=86400
ENABLE_RLS=true
ENABLE_USER_SYNC=false

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_REQUESTS=60
RATE_LIMIT_LOGIN_REQUESTS=5
RATE_LIMIT_TRUSTED_PROXIES=[]
